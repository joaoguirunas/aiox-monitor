{
  "name": "aiox-monitor",
  "version": "1.0.0",
  "description": "Real-time dashboard for AI agent monitoring with isometric virtual office",
  "author": "Joao Ramos",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joaoguirunas/aiox-monitor.git"
  },
  "homepage": "https://github.com/joaoguirunas/aiox-monitor",
  "keywords": [
    "ai",
    "agent",
    "monitor",
    "dashboard",
    "claude",
    "phaser",
    "isometric",
    "nextjs"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "aiox-monitor": "./bin/aiox-monitor.js"
  },
  "files": [
    "bin/",
    "src/",
    "public/",
    "server.ts",
    "next.config.mjs",
    "tsconfig.json",
    "tsconfig.server.json",
    "tailwind.config.ts",
    "postcss.config.mjs",
    "ecosystem.config.cjs",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "esbuild server.ts --bundle --platform=node --format=esm --packages=external --outfile=.server/server.mjs && node .server/server.mjs",
    "build": "esbuild server.ts --bundle --platform=node --format=esm --packages=external --outfile=.server/server.mjs && next build",
    "start": "node .server/server.mjs",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "install-hook": "tsx scripts/install-hook.ts",
    "uninstall-hook": "tsx scripts/uninstall-hook.ts",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop aiox-monitor",
    "pm2:restart": "pm2 restart aiox-monitor",
    "pm2:logs": "pm2 logs aiox-monitor --lines 50",
    "pm2:startup": "pm2 startup launchd && pm2 save",
    "pm2:status": "pm2 status",
    "setup": "bash scripts/setup.sh",
    "cleanup": "tsx scripts/cleanup.ts",
    "test": "tsx --test tests/*.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "lucide-react": "^0.469.0",
    "next": "^15.1.6",
    "phaser": "^3.87.0",
    "pm2": "^6.0.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.18.0",
    "yaml": "^2.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/ws": "^8.5.13",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "@playwright/test": "^1.49.0"
  }
}
